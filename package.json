{
  "name": "mcp-bifrost",
  "version": "0.1.0",
  "description": "Multi-workspace MCP bridge — connect multiple Notion, Slack, and other workspaces through a single MCP endpoint",
  "type": "module",
  "main": "server/index.js",
  "scripts": {
    "start": "node server/index.js",
    "dev": "node --watch server/index.js",
    "test": "node --test tests/",
    "test:coverage": "node --test --experimental-test-coverage tests/",
    "test:bench": "node --test --test-name-pattern=. tests/benchmarks/tool-registry.bench.js",
    "tunnel": "node scripts/tunnel.js"
  },
  "keywords": [
    "mcp",
    "notion",
    "slack",
    "multi-workspace",
    "bridge"
  ],
  "author": "Karnian",
  "license": "MIT",
  "homepage": "https://github.com/Karnian/mcp-bifrost#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Karnian/mcp-bifrost.git"
  },
  "bugs": {
    "url": "https://github.com/Karnian/mcp-bifrost/issues"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0"
  },
  "overrides": {
    "hono": "^4.12.14"
  }
}
